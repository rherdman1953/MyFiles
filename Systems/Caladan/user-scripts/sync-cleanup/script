      "$base/api/$apiver/history?page=$page&pageSize=$page_size&eventType=3" \
      -H "X-Api-Key: $key")
    echo "$resp" | jq -e '.records' > /dev/null 2>&1 || {
      log "ERROR: invalid history response from $base (page $page)" >&2
      return 1
    }
    echo "$resp" | jq -r '
      .records[]
