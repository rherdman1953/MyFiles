#!/bin/bash
# arr-import-monitor v2.0
# Monitors for stuck imports and sends Discord alerts.
# Runs every 15 minutes via Unraid User Scripts.
#
# Alert sources (both deduplicated via state file):
#   1. Filesystem: subfolders and loose .mkv files with .first_seen but no .imported
#      after IMPORT_ALERT_THRESHOLD minutes (default: 120)
#   2. Queue API: items stuck in importPending or importFailed state in Sonarr/Radarr
#
# State file: /tmp/arr-import-monitor.state
#   Keys:
#     fs:sonarr:FILENAME   — filesystem-based alert (subfolder or .mkv)
#     fs:radarr:FILENAME
#     queue:sonarr:QUEUE_ID
#     queue:radarr:QUEUE_ID
#
# Config overrides (optional, in arr-rescans.conf):
#   IMPORT_ALERT_THRESHOLD=120    # minutes before alerting on filesystem items
#   IMPORT_REALERT_SECONDS=3600   # seconds before re-alerting on same item

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

if [ ! -f /boot/config/arr-rescans.conf ]; then
  /usr/local/emhttp/webGui/scripts/notify \
    -e "arr-import-monitor" \
    -s "arr-import-monitor config missing" \
    -d "Config file /boot/config/arr-rescans.conf not found. Script cannot run." \
    -i "alert"
  exit 1
fi
source /boot/config/arr-rescans.conf

SONARR="http://192.168.1.12:8989"
RADARR="http://192.168.1.12:7878"

SONARR_SYNC="/mnt/user/media/download/sync/sonarr"
RADARR_SYNC="/mnt/user/media/download/sync/radarr"

THRESHOLD=${IMPORT_ALERT_THRESHOLD:-120}
REALERT=${IMPORT_REALERT_SECONDS:-3600}
STATE_FILE="/tmp/arr-import-monitor.state"

touch "$STATE_FILE"

# ---------------------------------------------------------------------------
# Notification (Discord + Unraid fallback)
# ---------------------------------------------------------------------------

send_notification() {
  local message="$1"
  local MSG=$(jq -n --arg msg "$message" '{content: $msg}')
  local HTTP_CODE=$(curl -s -o /tmp/discord_response.json -w "%{http_code}" \
    -X POST -H "Content-Type: application/json" \
    -d "$MSG" "$DISCORD_WEBHOOK")
  if [ "$HTTP_CODE" != "204" ]; then
    local ERROR=$(cat /tmp/discord_response.json 2>/dev/null)
    /usr/local/emhttp/webGui/scripts/notify \
      -e "arr-import-monitor" \
      -s "Discord webhook error" \
      -d "HTTP $HTTP_CODE: $ERROR — Message: $message" \
      -i "warning"
    echo "Discord failed (HTTP $HTTP_CODE), sent Unraid notification"
  fi
}

# ---------------------------------------------------------------------------
# Deduplication helpers
# State file format: KEY TIMESTAMP (one per line)
# ---------------------------------------------------------------------------

state_get() {
  # Returns the timestamp for a key, or empty string if not found
  grep -m1 "^$1 " "$STATE_FILE" 2>/dev/null | awk '{print $2}'
}

state_set() {
  # Upserts a key with current timestamp
  local key="$1"
  local now=$(date +%s)
  # Remove existing entry then append
  sed -i "/^$(echo "$key" | sed 's/[[\.*^$()+?{|]/\\&/g') /d" "$STATE_FILE"
  echo "$key $now" >> "$STATE_FILE"
}

state_delete() {
  local key="$1"
  sed -i "/^$(echo "$key" | sed 's/[[\.*^$()+?{|]/\\&/g') /d" "$STATE_FILE"
}

should_alert() {
  # Returns 0 (true) if we should alert: never alerted, or realert window has passed
  local key="$1"
  local last=$(state_get "$key")
  if [ -z "$last" ]; then
    return 0  # Never alerted
  fi
  local now=$(date +%s)
  local elapsed=$(( now - last ))
  if [ "$elapsed" -ge "$REALERT" ]; then
    return 0  # Realert window passed
  fi
  return 1  # Too soon to realert
}

# ---------------------------------------------------------------------------
# 1. Filesystem alerts — Sonarr subfolders
# ---------------------------------------------------------------------------

for item in "$SONARR_SYNC"/*/; do
  [ -d "$item" ] || continue
  [ -f "${item}.imported" ] && continue
  [ -f "${item}.first_seen" ] || continue  # Not yet seen by arr-rescans
  folder=$(basename "$item")
  key="fs:sonarr:$folder"

  marker_time=$(stat -c %Y "${item}.first_seen")
  now=$(date +%s)
  age=$(( (now - marker_time) / 60 ))

  if [ "$age" -gt "$THRESHOLD" ]; then
    if should_alert "$key"; then
      send_notification "⚠️ **Sonarr**: \`$folder\` has not imported after ${age} minutes"
      state_set "$key"
      echo "Alert (fs subfolder): $folder (${age} min)"
    fi
  fi
done

# ---------------------------------------------------------------------------
# 2. Filesystem alerts — Radarr subfolders
# ---------------------------------------------------------------------------

for item in "$RADARR_SYNC"/*/; do
  [ -d "$item" ] || continue
  [ -f "${item}.imported" ] && continue
  [ -f "${item}.first_seen" ] || continue
  folder=$(basename "$item")
  key="fs:radarr:$folder"

  marker_time=$(stat -c %Y "${item}.first_seen")
  now=$(date +%s)
  age=$(( (now - marker_time) / 60 ))

  if [ "$age" -gt "$THRESHOLD" ]; then
    if should_alert "$key"; then
      send_notification "⚠️ **Radarr**: \`$folder\` has not imported after ${age} minutes"
      state_set "$key"
      echo "Alert (fs subfolder): $folder (${age} min)"
    fi
  fi
done

# ---------------------------------------------------------------------------
# 3. Filesystem alerts — loose Sonarr .mkv files
# ---------------------------------------------------------------------------

for mkv in "$SONARR_SYNC"/*.mkv; do
  [ -f "$mkv" ] || continue
  [ -f "${mkv}.imported" ] && continue
  [ -f "${mkv}.first_seen" ] || continue
  filename=$(basename "$mkv")
  key="fs:sonarr:$filename"

  marker_time=$(stat -c %Y "${mkv}.first_seen")
  now=$(date +%s)
  age=$(( (now - marker_time) / 60 ))

  if [ "$age" -gt "$THRESHOLD" ]; then
    if should_alert "$key"; then
      send_notification "⚠️ **Sonarr**: \`$filename\` has not imported after ${age} minutes"
      state_set "$key"
      echo "Alert (fs mkv): $filename (${age} min)"
    fi
  fi
done

# ---------------------------------------------------------------------------
# 4. Filesystem alerts — loose Radarr .mkv files
# ---------------------------------------------------------------------------

for mkv in "$RADARR_SYNC"/*.mkv; do
  [ -f "$mkv" ] || continue
  [ -f "${mkv}.imported" ] && continue
  [ -f "${mkv}.first_seen" ] || continue
  filename=$(basename "$mkv")
  key="fs:radarr:$filename"

  marker_time=$(stat -c %Y "${mkv}.first_seen")
  now=$(date +%s)
  age=$(( (now - marker_time) / 60 ))

  if [ "$age" -gt "$THRESHOLD" ]; then
    if should_alert "$key"; then
      send_notification "⚠️ **Radarr**: \`$filename\` has not imported after ${age} minutes"
      state_set "$key"
      echo "Alert (fs mkv): $filename (${age} min)"
    fi
  fi
done

# ---------------------------------------------------------------------------
# 5. Queue API alerts — Sonarr importPending / importFailed
# ---------------------------------------------------------------------------

SONARR_QUEUE=$(curl -s "http://192.168.1.12:8989/api/v3/queue?pageSize=100" \
  -H "X-Api-Key: $SONARR_KEY")

now=$(date +%s)

echo "$SONARR_QUEUE" | jq -c '.records[] | select(.status == "completed" and
  (.trackedDownloadStatus == "warning" or .trackedDownloadStatus == "error"))' 2>/dev/null | \
while read -r record; do
  id=$(echo "$record" | jq -r '.id')
  title=$(echo "$record" | jq -r '.title')
  status=$(echo "$record" | jq -r '.trackedDownloadStatus')
  key="queue:sonarr:$id"

  if should_alert "$key"; then
    send_notification "🔴 **Sonarr queue stuck** (\`$status\`): \`$title\`"
    state_set "$key"
    echo "Alert (queue): Sonarr $title ($status)"
  fi
done

# Clean up resolved Sonarr queue entries from state
while IFS=' ' read -r key timestamp; do
  [[ "$key" == queue:sonarr:* ]] || continue
  id="${key#queue:sonarr:}"
  still_present=$(echo "$SONARR_QUEUE" | jq --arg id "$id" \
    '.records[] | select(.id == ($id | tonumber))' 2>/dev/null)
  if [ -z "$still_present" ]; then
    state_delete "$key"
    echo "Cleared resolved Sonarr queue entry: $id"
  fi
done < "$STATE_FILE"

# ---------------------------------------------------------------------------
# 6. Queue API alerts — Radarr importPending / importFailed
# ---------------------------------------------------------------------------

RADARR_QUEUE=$(curl -s "http://192.168.1.12:7878/api/v3/queue?pageSize=100" \
  -H "X-Api-Key: $RADARR_KEY")

echo "$RADARR_QUEUE" | jq -c '.records[] | select(.status == "completed" and
  (.trackedDownloadStatus == "warning" or .trackedDownloadStatus == "error"))' 2>/dev/null | \
while read -r record; do
  id=$(echo "$record" | jq -r '.id')
  title=$(echo "$record" | jq -r '.title')
  status=$(echo "$record" | jq -r '.trackedDownloadStatus')
  key="queue:radarr:$id"

  if should_alert "$key"; then
    send_notification "🔴 **Radarr queue stuck** (\`$status\`): \`$title\`"
    state_set "$key"
    echo "Alert (queue): Radarr $title ($status)"
  fi
done

# Clean up resolved Radarr queue entries from state
while IFS=' ' read -r key timestamp; do
  [[ "$key" == queue:radarr:* ]] || continue
  id="${key#queue:radarr:}"
  still_present=$(echo "$RADARR_QUEUE" | jq --arg id "$id" \
    '.records[] | select(.id == ($id | tonumber))' 2>/dev/null)
  if [ -z "$still_present" ]; then
    state_delete "$key"
    echo "Cleared resolved Radarr queue entry: $id"
  fi
done < "$STATE_FILE"

echo "arr-import-monitor complete"
